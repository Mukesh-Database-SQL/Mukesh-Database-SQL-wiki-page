Fetch the SCCM 2012 Data Visio and Project using collid



truncate table SCCM2012_APPLICATION_EXCLUDED_DATA
Go
	-- This Script is Developed by HCL Technologies version V.0
	-- This Script will fetch data  from v_R_System,v_Add_Remove_Programs,v_FullCollectionMembership,v_R_User in accordance with CollId.
Declare @displayname nvarchar(7),@CollID nvarchar(8), @Publisher0 nvarchar(50)
Declare Coll_cursor Cursor for 
Select ColID from [dbo].[collID] -- This will select the CollID from collID table
open Coll_cursor
Fetch next from Coll_cursor into @CollID
while @@FETCH_STATUS = 0
Begin  
Set @displayname ='%Visio%'
set @Publisher0 ='Microsoft Corporation'
INSERT INTO [SCCM2012_APPLICATION_EXCLUDED_DATA] -- This insertion will instert the data into SCCM_2012_Application_Excluded_data
SELECT	sys.Netbios_Name0, 
		sys.User_Name0,
		@Publisher0 as Publisher0,
		arp.DisplayName0,
		arp.Version0,
		arp.InstallDate0
FROM				dbo.v_R_System AS sys 
INNER JOIN			dbo.v_Add_Remove_Programs AS arp ON sys.ResourceID = arp.ResourceID 
INNER JOIN			dbo.v_FullCollectionMembership AS fcm ON sys.ResourceID = fcm.ResourceID 
Left Outer JOIN		dbo.v_R_User U ON sys.User_Name0 = U.User_Name0 
WHERE  
		arp.DisplayName0 like @displayname 
 AND	fcm.CollectionID = @CollID
 AND	arp.displayname0 NOT IN (select * from [dbo].[Exclusion2012]) --This will match condition for Excluded Application from table Exclusion2012
Fetch next from Coll_cursor into @CollID
End
Close Coll_cursor
Deallocate Coll_cursor
