Snippet#8 - Maintenance Plans Manipulation via TSQL

These scripts can be run in SQL Server 2005 and 2008.

Use them if Sql Server Management Studio does not perform the manipulation you desire.



USE msdb
GO
#List all Maintenance Plans within the active SQL Server.
SELECT * FROM sysmaintplan_plans
#Delete the maintenance plan based on the id listed from the above query.
#Use this if SSMS is reporting an error.
DELETE FROM sysmaintplan_log WHERE plan_id = @id
DELETE FROM sysmaintplan_subplans WHERE plan_id = @id
DELETE FROM sysmaintplan_plans WHERE id = @id
#Update the Name of the Maintenance Plan.
UPDATE sysmaintplan_plans SET name = '<NEW PLAN NAME>' where name='<OLD PLAN NAME>';
#Query Information based on a Plan ID.
select * FROM sysmaintplan_plans WHERE id ='<PLAN_ID>'
select * FROM sysmaintplan_subplans WHERE plan_id ='<PLAN_ID>'
#Change the Owner of the Maintenance Plan
#First identify the SID of the owner you wish to change the owner to. 
SELECT [name],[sid]  FROM [msdb].[sys].[sql_logins]
#Update the Owner of the Maintenance Plan to the SID extracted from the above query.
UPDATE msdb.dbo.sysssispackages
SET [ownersid]=<SID of new owner>
WHERE [name]='YourMaintPlanName'
