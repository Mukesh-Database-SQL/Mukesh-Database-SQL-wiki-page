io_virtual_file_stats
SELECT 
    DB_NAME (f.database_id) AS database_name, f.database_id, f.name AS logical_file_name, f.[file_id], f.type_desc, 
    CAST (CASE 
        -- Handle UNC paths (e.g. '\\fileserver\readonlydbs\dept_dw.ndf' --> '\\fileserver\readonlydbs')
        WHEN LEFT (LTRIM (f.physical_name), 2) = '\\' 
            THEN LEFT (LTRIM (f.physical_name), CHARINDEX ('\', LTRIM (f.physical_name), CHARINDEX ('\', LTRIM (f.physical_name), 3) + 1) - 1)
        -- Handle local paths (e.g. 'C:\Program Files\...\master.mdf' --> 'C:') 
        WHEN CHARINDEX ('\', LTRIM(f.physical_name), 3) > 0 
            THEN UPPER (LEFT (LTRIM (f.physical_name), CHARINDEX ('\', LTRIM (f.physical_name), 3) - 1))
        ELSE f.physical_name
    END AS nvarchar(255)) AS logical_disk, 
    fs.num_of_reads, fs.num_of_bytes_read, fs.io_stall_read_ms, fs.num_of_writes, fs.num_of_bytes_written, 
    fs.io_stall_write_ms, fs.size_on_disk_bytes
FROM sys.dm_io_virtual_file_stats (default, default) AS fs
INNER JOIN sys.master_files AS f ON fs.database_id = f.database_id AND fs.[file_id] = f.[file_id]
Snippet#6 - Removes a Specific Plan from the Plan Cache by Specifying a Plan Handle.

This script can be run in SQL 2005 and 2008 but only in 2008 can a plan_handle be provided as

a parameter for FREEPROCCACHE. In 2005 running FREEPROCCACHE clears all the cached plans.



--The following example will provide the plan_handles for the cached plans that contains the SQL
--N'%SELECT "dbo"."tblTask"."TOP_TASK_ID"%'. You must then determine which plan_handle is the one
--that should be used or make the SQL that is being searched for more specific.
SELECT plan_handle, st.text
FROM sys.dm_exec_cached_plans
CROSS APPLY sys.dm_exec_sql_text(plan_handle) AS st
WHERE text LIKE N'%SELECT "dbo"."tblTask"."TOP_TASK_ID"%';
GO
--The following example will remove the specific plan from the cache that was identified from the above query.
--This is only for MS SQL 2008.
DBCC FREEPROCCACHE (0x060007003E05782540E3A5CE010000000000000000000000);
GO
--For MS SQL 2005 run the following which will clear all the plans from the cache.
DBCC FREEPROCCACHE;
GO
