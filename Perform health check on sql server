Database Count (HCL, BASE R1, BASE R2) and analysis count use for Monthly Report



DECLARE @end_date datetime
SET @end_date = '2016-06-10'
SELECT a.System_Code, b.Infrastructure_Type, b.Computer_Name, (CASE 
            WHEN b.Product_Version like '8.0%' THEN 'SQL Server 2000'
            WHEN b.Product_Version like '9.0%' THEN 'SQL Server 2005'
            WHEN b.Product_Version like '10.50%' THEN 'SQL Server 2008 R2'
            WHEN b.Product_Version like '11%' THEN 'SQL Server 2012'
	    WHEN b.Product_Version like '12%' THEN 'SQL Server 2014'
            WHEN b.Product_Version like '13%' THEN 'SQL Server 2016'
      ELSE NULL END) Product_Version, a.Database_Name, CAST((a.Database_Size_MBs/1024.0) AS decimal(10,6)) AS Database_Size_GBs,
a.Application_Name, b.Environment, b.Support, c.DataCenter, a.status,
b.Server_Name, a.Creation_Date, b.Mainstream_Support
from bcc.mssql_server b
join bcc.mssql_database a
on a.server_id = b.server_id
join bcc.MSSQL_Datacenter_details c
on b.Computer_Name = c.Computer_Name
where a.database_name NOT IN ('model','msdb','DBA_Maintenance','tempdb','master')
and a.decommission_date is NULL
and b.decommission_date IS NULL
and c.Instance_Name = b.Server_Name
and a.first_recorded_date <= @end_date
UNION
select NULL AS System_Code, b.Infrastructure_Type, b.Computer_Name, (CASE 
            WHEN b.Product_Version like '8.0%' THEN 'SQL Server 2000'
            WHEN b.Product_Version like '9.0%' THEN 'SQL Server 2005'
            WHEN b.Product_Version like '10.50%' THEN 'SQL Server 2008 R2'
            WHEN b.Product_Version like '11%' THEN 'SQL Server 2012'
	    WHEN b.Product_Version like '12%' THEN 'SQL Server 2014'
            WHEN b.Product_Version like '13%' THEN 'SQL Server 2016'
      ELSE NULL END) Product_Version, a.Analysis_Database_Name, 
CAST((a.analysis_database_size_MBs/1024.0) AS Decimal(10,6)) AS Database_Size_GBs,
a.Application_Name, b.Environment, b.Support, c.DataCenter, a.status,
b.Analysis_Server_Name, a.First_Recorded_Date, b.Mainstream_Support
from bcc.mssql_analysis_server b
join bcc.mssql_analysis_database a
on a.analysis_server_id = b.analysis_server_id
join bcc.MSSQL_datacenter_details c
on b.Computer_Name = c.Computer_Name
and a.decommission_date iS NULL
and b.decommission_date IS NULL
and a.first_recorded_date <= @end_date
