Database Backup Status (Not Backed up more than 2 day's)



use Database_Central
go
select s.Computer_Name,s.Server_Name as [SQL Server Instance Name],(CASE 
            WHEN s.Product_Version like '8.0%' THEN 'SQL Server 2000'
            WHEN s.Product_Version like '9.0%' THEN 'SQL Server 2005'
            WHEN s.Product_Version like '10.50%' THEN 'SQL Server 2008 R2'
            WHEN s.Product_Version like '11%' THEN 'SQL Server 2012'
	    WHEN b.Product_Version like '12%' THEN 'SQL Server 2014'
            WHEN b.Product_Version like '13%' THEN 'SQL Server 2016'
      ELSE NULL END) Product_Version,d.Database_Name,d.Status,d.Recovery_Model,d.Last_Database_Backup_Date,
      d.Last_Database_Log_Backup_Date, s.Environment,s.support
from bcc.MSSQL_Database d, Database_central.bcc.MSSQL_Server s 
where s.Server_ID = d.Server_ID
and d.decommission_date is null 
and s.support not in ('Sirsi Dynix')
and d.Database_Name not in ('tempdb')
and d.Database_Snapshot IS NULL and Status='ONLINE' 
and Last_Database_Backup_Date<getdate()-2
